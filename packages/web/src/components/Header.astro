      <a href="/notificacoes" class="px-3 py-2 text-sm rounded-md hover:bg-accent transition-colors">Notificacoes</a>
      <a href="https://api.refsus.nauraki.com/docs" target="_blank" rel="noopener noreferrer" class="px-3 py-2 text-sm font-medium rounded-md hover:bg-accent transition-colors">API Docs</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const nav = document.getElementById("mobile-nav");

  btn?.addEventListener("click", () => {
    nav?.classList.toggle("hidden");
  });
</script>
