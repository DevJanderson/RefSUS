      <a href="/" class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary">
          <span class="text-sm font-bold text-primary-foreground">RS</span>
        </div>
        <span class="font-bold">RefSUS</span>
        <span class="text-muted-foreground">|</span>
        <span class="text-sm font-semibold">Dados SUS</span>
      </a>

      <!-- nav links -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class="px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
          Inicio
        </a>
        <a href="/doencas" class="px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
          Doencas
        </a>
        <a href="/regioes" class="px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
          Regioes
        </a>
        <a href="/notificacoes" class="px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
          Notificacoes
        </a>
        <a href="https://api.refsus.nauraki.com/docs" target="_blank" rel="noopener noreferrer" class="px-3 py-1.5 text-sm font-medium text-foreground hover:text-primary transition-colors">
          API Docs
        </a>
