    </div>

    <!-- right: search + github + theme -->
    <div class="flex items-center gap-3">
      <!-- search -->
      <a href="/#busca" class="hidden sm:flex items-center gap-2 rounded-md border border-input bg-muted/40 px-3 py-1.5 text-sm text-muted-foreground hover:bg-muted transition-colors w-44 lg:w-56">
