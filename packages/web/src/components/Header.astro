    <nav class="container mx-auto flex flex-col px-4 py-3 gap-1">
      <a href="/" class="px-3 py-2 text-sm rounded-md hover:bg-accent transition-colors">Inicio</a>
      <a href="/doencas" class="px-3 py-2 text-sm rounded-md hover:bg-accent transition-colors">Doencas</a>
